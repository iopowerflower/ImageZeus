<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ImageViewer.App.App"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <SimpleTheme />
    <StyleInclude Source="avares://ImageZeus/Styles.axaml" />
  </Application.Styles>

  <TrayIcon.Icons>
    <TrayIcons>
      <TrayIcon Icon="avares://ImageZeus/Assets/zeusicon.ico"
                ToolTipText="ImageZeus">
        <TrayIcon.Menu>
          <NativeMenu>
            <NativeMenuItem Header="Exit ImageZeus" Click="OnTrayExitClick" />
          </NativeMenu>
        </TrayIcon.Menu>
      </TrayIcon>
    </TrayIcons>
  </TrayIcon.Icons>
</Application>
